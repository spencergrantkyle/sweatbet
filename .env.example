# SweatBet Environment Variables
# Copy this file to .env and fill in the values

# Strava OAuth (from https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REDIRECT_URI=http://localhost:5000/auth/callback
STRAVA_WEBHOOK_VERIFY_TOKEN=SWEATBET_WEBHOOK_TOKEN

# Telegram Bot (for admin notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Session
SECRET_KEY=change-this-to-a-random-string-in-production

# Admin docs login
USER_NAME=admin
PASSWORD=admin

# Database (production only - dev uses SQLite automatically)
# DATABASE_URL=postgresql://user:pass@host:5432/sweatbet

# Scheduler
SCHEDULER_ENABLED=True
ACTIVITY_CHECK_INTERVAL_MINUTES=5
REMINDER_CHECK_INTERVAL_HOURS=1
REMINDER_COOLDOWN_HOURS=24
ACTIVITY_LOOKBACK_HOURS=24
