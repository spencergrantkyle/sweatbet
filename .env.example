# SweatBet Environment Configuration

# Environment mode: dev or prod
ENV_MODE=dev

# Session secret (REQUIRED in prod - generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=

# Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database (prod only)
DATABASE_URL=

# Host URL (prod only)
HOST_URL=

# Scheduler
SCHEDULER_ENABLED=True
ACTIVITY_CHECK_INTERVAL_MINUTES=5
REMINDER_CHECK_INTERVAL_HOURS=1
REMINDER_COOLDOWN_HOURS=24
ACTIVITY_LOOKBACK_HOURS=24
